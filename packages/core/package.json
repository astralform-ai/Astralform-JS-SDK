{
  "name": "@astralform/js",
  "version": "1.0.0",
  "description": "Astralform JS SDK - AI agent orchestration with WebMCP support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "astralform",
    "ai",
    "agent",
    "llm",
    "webmcp",
    "mcp",
    "sse",
    "streaming"
  ],
  "author": "Astralform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/astralform-ai/Astralform-JS-SDK"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
